{
  "name": "landnote",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:bff": "node server/index.js",
    "dev:all": "concurrently \"npm run dev:bff\" \"npm run dev\"",
    "build": "vite build",
    "db:clear-test-data": "node scripts/clear-supabase-test-data.mjs",
    "verify:auth": "node scripts/verify-auth-flow.mjs",
    "verify:b2b": "node scripts/verify-b2b-team.mjs",
    "preview": "vite preview",
    "start": "node server/index.js --static",
    "start:bff": "node server/index.js",
    "cap:sync": "npm run build && npx cap sync",
    "cap:android": "npm run cap:sync && npx cap open android",
    "cap:ios": "npm run cap:sync && npx cap open ios",
    "tailwind-init": "tailwindcss init -p"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.2",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "concurrently": "^9.2.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.19",
    "vite": "^8.1.2"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.2",
    "@capacitor/core": "^7.4.2",
    "@capacitor/ios": "^7.4.2",
    "@supabase/supabase-js": "^2.57.4",
    "axios": "^1.18.1",
    "cors": "^2.8.5",
    "dexie": "^4.4.4",
    "dexie-react-hooks": "^4.4.0",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "http-proxy-middleware": "^3.0.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "xlsx": "^0.18.5"
  }
}
