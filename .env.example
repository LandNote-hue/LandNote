# ── juso.go.kr (주소기반산업지원서비스 → API신청) ──
# 검색 API와 팝업 API는 승인키가 서로 다릅니다. 둘 다 필요하면 각각 신청하세요.

# [필수] 도로명주소 검색 API — 앱 내 주소 검색 모달 (addrLinkApi.do)
VITE_JUSO_SEARCH_KEY=

# [선택] 도로명주소 팝업 API — 공식 새창 (addrLinkUrl.do)
# 신청 시 사이트 URL·returnUrl 등록 필요 (예: http://localhost:5175/juso-return.html)
VITE_JUSO_POPUP_KEY=
VITE_JUSO_POPUP_MOBILE_KEY=

# 하위 호환 (POPUP_KEY / SEARCH_KEY 미설정 시 대체)
VITE_JUSO_CONFIRM_KEY=
VITE_JUSO_MOBILE_KEY=

# data.go.kr — 국토교통부 건축HUB 건축물대장정보 (Encoding 또는 Decoding 키)
VITE_DATA_GO_KR_SERVICE_KEY=

# vworld.kr — 개별공시지가·토지특성 (발급 시 등록한 domain과 동일하게)
VITE_VWORLD_API_KEY=
VITE_VWORLD_DOMAIN=localhost

# ── kakao developers (map) ──
# JavaScript 키 — 카카오맵 SDK (REST 키 아님)
# 등록 위치: [앱] → [플랫폼 키] → [JavaScript 키] → [JavaScript SDK 도메인]
#   http://localhost:5175  (제품 링크 관리 ≠ SDK 도메인)
VITE_KAKAO_MAP_JS_KEY=
# REST API 키 — 서버/프록시용 (현재 앱은 JS SDK Geocoder 사용)
VITE_KAKAO_REST_API_KEY=

# ── Supabase (인증 + 클라우드 DB) ──
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Google OAuth Web Client ID (GIS / signInWithIdToken — Supabase Client Secret 불필요)
VITE_GOOGLE_CLIENT_ID=
# Supabase 미설정 시 로컬 개발용 인증 우회 (운영: false)
VITE_AUTH_DEV_BYPASS=true
# BFF/서버 전용 (절대 VITE_ 붙이지 마세요)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── API BFF ──
VITE_BFF_BASE_URL=
# dev: Vite가 BFF로 프록시 (npm run dev:all)
VITE_USE_BFF=false
VITE_BFF_DEV_URL=http://localhost:3001
BFF_PORT=3001

# VITE_PUBLIC_DATA_BASE_URL=
# VITE_VWORLD_BASE_URL=
# VITE_EUM_BASE_URL=
# VITE_JUSO_API_BASE_URL=
